    "@solana/web3.js": "^1.98.4",
    "alchemy-sdk": "^3.6.5",
    "argon2": "^0.44.0",
    "ethers": "^6.0.0",
    "uuid": "^14.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "typescript": "^6.0.3"
  }
}
