  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node bin/jellyos",
    "setup": "bash setup.sh",
    "build": "tsc --project tsconfig.json",
    "type-check": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
