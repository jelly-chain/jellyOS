{
  "name": "@jellyos/pi-package",
  "version": "2.0.0",
  "description": "JellyOS — AI blockchain analytics and trading agent (standalone, Pi-free)",
  "keywords": [
    "blockchain",
    "trading",
    "ai",
    "defi",
    "crypto",
    "agent",
    "jelly"
  ],
  "bin": {
    "jellyos": "./bin/jellyos",
    "jelly": "./bin/jellyos"
